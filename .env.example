# =============================================================================
# CM ENGLISH INSTRUCTOR — VARIABLES DE ENTORNO
# =============================================================================
# Copia este archivo a .env y llena con tus valores locales.
# NUNCA commitees .env al repositorio (ya está en .gitignore).
# =============================================================================

# -----------------------------------------------------------------------------
# Application
# -----------------------------------------------------------------------------
NODE_ENV=development
# URL pública de la aplicación (usada en emails, links de invitación, OAuth)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# -----------------------------------------------------------------------------
# Database
# -----------------------------------------------------------------------------
# Hay dos formas según el modo de deploy:
#
# a) DEV LOCAL o Dokploy Application + Postgres administrado:
#    Setear DATABASE_URL directamente con la connection string.
#    Local:         postgresql://postgres:postgres@localhost:5432/cm_english
#    Neon/Supabase: usar la cadena del proveedor (con ?sslmode=require)
#
# b) DOKPLOY COMPOSE APPLICATION:
#    NO setear DATABASE_URL — el docker-compose.yml la construye desde
#    POSTGRES_USER / POSTGRES_PASSWORD / POSTGRES_DB (ver abajo).
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/cm_english"

# Solo necesario en modo Compose. El compose la usa para inicializar Postgres
# y para construir DATABASE_URL como:
#   postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@db:5432/${POSTGRES_DB}
POSTGRES_USER=cmuser
POSTGRES_PASSWORD=
POSTGRES_DB=cmenglish

# -----------------------------------------------------------------------------
# Auth.js (NextAuth v5)
# -----------------------------------------------------------------------------
# Generar con: openssl rand -base64 32
AUTH_SECRET=""
# En producción, debe coincidir con NEXT_PUBLIC_APP_URL sin trailing slash
AUTH_URL=http://localhost:3000

# -----------------------------------------------------------------------------
# Storage
# -----------------------------------------------------------------------------
# Driver: "local" (default) o "r2"
STORAGE_DRIVER=local

# -- Local driver --
# Ruta relativa donde se guardan los archivos cuando STORAGE_DRIVER=local
LOCAL_STORAGE_PATH=./storage

# -- Cloudflare R2 driver (para cuando migres) --

# -----------------------------------------------------------------------------
# Email
# -----------------------------------------------------------------------------
# Provider: "console" (dev, imprime en logs), "smtp" (producción)
EMAIL_PROVIDER=console

# -- SMTP del dominio (cPanel / Plesk / VPS) --
# Estos valores los provee el panel del hosting al crear una cuenta de correo.
SMTP_HOST=mail.cmenglishinstructor.com
SMTP_PORT=587
SMTP_USER=no-reply@cmenglishinstructor.com
SMTP_PASSWORD=
# true para TLS implícito (puerto 465); false para STARTTLS (puerto 587, recomendado)
SMTP_SECURE=false

EMAIL_FROM="CM English Instructor <no-reply@cmenglishinstructor.com>"
EMAIL_REPLY_TO=coordinacion@cmenglishinstructor.com

# -----------------------------------------------------------------------------
# Timezone
# -----------------------------------------------------------------------------
# Zona horaria por defecto para mostrar fechas/horas al usuario.
# Los slots de disponibilidad (HH:mm) se interpretan en esta zona.
DEFAULT_TIMEZONE=America/Guayaquil

# -----------------------------------------------------------------------------
# Cron / jobs
# -----------------------------------------------------------------------------
# El scheduler corre in-process dentro del contenedor (ver
# src/lib/jobs/scheduler.ts) — no requiere servicio externo. Este secret
# protege los endpoints /api/cron/* que quedan como respaldo manual (curl
# desde el host, monitoreo, etc.).
# Generar con: openssl rand -hex 32
CRON_SECRET=""

# -----------------------------------------------------------------------------
# Cloudflare Turnstile (captcha de forms públicos)
# -----------------------------------------------------------------------------
# Site key (público — viaja al cliente) y secret key (server-only) para
# /postular-docente y el form de contacto del landing.
#
# Si AMBAS quedan vacías, el captcha se desactiva y los forms quedan
# protegidos solo por rate-limit por IP. Es el modo recomendado para
# arranque — siempre se puede activar más tarde cuando el tráfico crezca.
#
# IMPORTANTE: `NEXT_PUBLIC_TURNSTILE_SITE_KEY` se inyecta en el bundle del
# cliente en build-time (no en runtime). Si querés activar Turnstile en
# producción, hay que pasar la site key como build ARG al Dockerfile y al
# compose, no solo en el panel de Environment de Dokploy.
# https://dash.cloudflare.com/?to=/:account/turnstile
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# -----------------------------------------------------------------------------
# Observability (opcional para dev, recomendado para producción)
# -----------------------------------------------------------------------------

# -----------------------------------------------------------------------------
# Feature flags
# -----------------------------------------------------------------------------
# Modo demo: desactiva envío real de emails (siempre usa provider "console").
# Útil para demos con la directora sin riesgo de mandar correos de prueba.
DEMO_MODE=false

# -----------------------------------------------------------------------------
# Bootstrap del super administrador (DIRECTOR)
# -----------------------------------------------------------------------------
# Lo lee `prisma/seed.production.ts` la primera vez que arranca el contenedor
# en Dokploy. La cuenta se crea con rol DIRECTOR; la contraseña queda hasheada
# con bcrypt. Después del primer login se puede cambiar desde la UI — el seed
# es idempotente y NO sobreescribe la pass en arranques posteriores.
#
# IMPORTANTE: usá una contraseña fuerte. Mínimo 12 caracteres con mayúsculas,
# minúsculas, números y símbolos.
SUPER_ADMIN_EMAIL=
SUPER_ADMIN_PASSWORD=
SUPER_ADMIN_FIRST_NAME=Director
SUPER_ADMIN_LAST_NAME=Principal
# Opcionales — útiles para la primera vez que entres al panel.
SUPER_ADMIN_DOCUMENT=
SUPER_ADMIN_PHONE=